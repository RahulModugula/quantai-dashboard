# QuantAI Configuration - Copy to .env and customize

# TICKERS & DATA
QUANTAI_TICKERS="AAPL,MSFT,GOOGL,AMZN,SPY"
QUANTAI_LOOKBACK_YEARS=5

# DATABASE
QUANTAI_DB_PATH="data/trading.db"

# MODEL
QUANTAI_WALK_FORWARD_WINDOW=252
QUANTAI_RETRAIN_INTERVAL=63
QUANTAI_SEQUENCE_LENGTH=20
QUANTAI_ENSEMBLE_WEIGHTS='{"rf": 0.3, "xgb": 0.3, "lgbm": 0.25, "lstm": 0.15}'

# TRADING
QUANTAI_INITIAL_CAPITAL=100000.0
QUANTAI_MAX_POSITION_PCT=0.10
QUANTAI_COMMISSION_PCT=0.001
QUANTAI_BUY_THRESHOLD=0.60
QUANTAI_SELL_THRESHOLD=0.40
QUANTAI_MAX_DRAWDOWN_LIMIT=0.20

# API
QUANTAI_REDIS_URL="redis://localhost:6379"
QUANTAI_WS_UPDATE_INTERVAL=2.0
QUANTAI_API_HOST="0.0.0.0"
QUANTAI_API_PORT=8000

# FINANCIAL
QUANTAI_DEFAULT_INFLATION_RATE=0.06
QUANTAI_DEFAULT_TAX_RATE=0.30
