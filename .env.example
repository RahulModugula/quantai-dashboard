# QuantAI Configuration - Copy to .env and customize

# TICKERS & DATA
QUANTAI_TICKERS='["AAPL","MSFT","GOOGL","AMZN","SPY"]'
QUANTAI_LOOKBACK_YEARS=5

# DATABASE
QUANTAI_DB_PATH="data/trading.db"

# MODEL
QUANTAI_WALK_FORWARD_WINDOW=252
QUANTAI_RETRAIN_INTERVAL=63
QUANTAI_SEQUENCE_LENGTH=20
QUANTAI_ENSEMBLE_WEIGHTS='{"rf": 0.3, "xgb": 0.3, "lgbm": 0.25, "lstm": 0.15}'

# TRADING
QUANTAI_INITIAL_CAPITAL=100000.0
QUANTAI_MAX_POSITION_PCT=0.10
QUANTAI_COMMISSION_PCT=0.001
QUANTAI_BUY_THRESHOLD=0.60
QUANTAI_SELL_THRESHOLD=0.40
QUANTAI_MAX_DRAWDOWN_LIMIT=0.20

# API
QUANTAI_REDIS_URL="redis://localhost:6379"
QUANTAI_WS_UPDATE_INTERVAL=2.0
QUANTAI_API_HOST="0.0.0.0"
QUANTAI_API_PORT=8000

# FINANCIAL
QUANTAI_DEFAULT_INFLATION_RATE=0.06
QUANTAI_DEFAULT_TAX_RATE=0.30

# ENVIRONMENT (development | production)
QUANTAI_ENV="development"

# LOGGING (structlog: json in production, console in development)
QUANTAI_LOG_LEVEL="INFO"

# AGENT INTELLIGENCE (QuantAI Intel)
# LiteLLM is model-agnostic — swap QUANTAI_AGENT_MODEL without touching agent code.
#
# Recommended models (all support tool use + ≥128K context):
#
#   openrouter/x-ai/grok-4.20                      — $2/$6 per M, 2M ctx, fast agentic (default)
#   openrouter/anthropic/claude-opus-4.7            — $5/$25 per M, 1M ctx, best reasoning
#   openrouter/google/gemini-3.1-pro-preview        — $2/$12 per M, 1M ctx, strong structured output
#   openrouter/qwen/qwen3-max-thinking              — $0.78/$3.9 per M, 262K ctx, budget pick
#   openrouter/nvidia/nemotron-3-super-120b-a12b:free — FREE, 262K ctx, good for dev/demo
#   ollama/llama3                                   — local/free, no API key needed
#
QUANTAI_AGENT_MODEL="openrouter/x-ai/grok-4.20"
QUANTAI_AGENT_TIMEOUT_SECONDS=30

# OpenRouter API key — covers all openrouter/* models above
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Direct provider keys (only needed if NOT using OpenRouter)
# ANTHROPIC_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
